{
  "name": "monosize-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "e2e/*"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/monosize"
  },
  "scripts": {
    "build": "nx affected:build",
    "change": "beachball change --no-commit",
    "check-dependencies": "syncpack lint",
    "lint": "nx affected:lint",
    "test": "nx affected:test"
  },
  "nano-staged": {
    "**/*.{js,json,ts,tsx}": "prettier --write",
    "**/*.{md}": "doctoc -u"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "packageManager": "yarn@4.15.0",
  "devDependencies": {
    "@eslint/js": "~10.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/vitest": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@types/adm-zip": "0.5.8",
    "@types/node": "26.1.0",
    "@types/yargs": "17.0.35",
    "@vitest/coverage-v8": "4.1.5",
    "beachball": "2.65.4",
    "doctoc": "2.5.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.17.0",
    "eslint-plugin-unicorn": "71.1.0",
    "nano-staged": "1.0.2",
    "nx": "23.0.1",
    "prettier": "3.9.4",
    "simple-git-hooks": "2.13.1",
    "syncpack": "15.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@rsbuild/core": "^2.1.2",
    "@upstash/redis": "^1.38.0",
    "acorn": "^8.17.0",
    "adm-zip": "^0.5.17",
    "ci-info": "^4.2.0",
    "cli-table3": "^0.6.5",
    "empathic": "^2.0.0",
    "pretty-bytes": "^7.1.0",
    "terser": "^5.48.0",
    "terser-webpack-plugin": "^5.6.0",
    "tinyglobby": "^0.2.13",
    "tslib": "^2.4.1",
    "vite": "^8.1.0",
    "webpack": "^5.108.3",
    "yargs": "^18.0.0"
  }
